PORT=4173
NODE_ENV=development
KAKAO_CLIENT_ID=<your-client-id>
KAKAO_CLIENT_SECRET=<your-client-secret>
# Redirect URI should match the kakao app config.
# In production, use your HTTPS domain callback.
# If omitted (or set to localhost behind a real domain), server falls back to https://{host}/api/auth/kakao/callback.
KAKAO_REDIRECT_URI=http://localhost:4173/api/auth/kakao/callback
DATABASE_PATH=daycheck.sqlite
SESSION_SECRET=<random-long-secret>
# REQUIRED in all environments. Server startup fails if missing/invalid.
# Must be a 32-byte key (base64, hex, or utf8 32 chars).
SESSION_ENCRYPTION_KEY=<base64-or-hex-32-byte-key>
# Optional: absolute session lifetime in ms (default 2592000000 = 30d)
SESSION_ABSOLUTE_TTL_MS=2592000000
HOLIDAY_API_PROVIDER=public_data_portal
HOLIDAY_API_SERVICE_KEY=<public-data-service-key>
HOLIDAY_API_BASE_URL=https://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService/getRestDeInfo
# Fallback feed (Google Korea holidays ICS) when provider call fails or key is missing.
HOLIDAY_FEED_URL=https://calendar.google.com/calendar/ical/ko.south_korea%23holiday%40group.v.calendar.google.com/public/basic.ics
HOLIDAY_CLIENT_CACHE_TTL_MS=86400000
POLL_STATE_ACTIVE_MS=4000
POLL_STATE_HIDDEN_MS=20000
POLL_COLLAB_ACTIVE_MS=6000
POLL_COLLAB_HIDDEN_MS=30000
SECURITY_EVENT_LOG_PATH=security-events.log
# Optional: rotate security log at this size in bytes (default 10485760 = 10MB)
SECURITY_EVENT_LOG_MAX_BYTES=10485760
SECURITY_EVENTS_ENABLED=true
AUTH_SUCCESS_REDIRECT=/?auth=success


