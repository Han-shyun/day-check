PORT=4173
NODE_ENV=development
NAVER_CLIENT_ID=<your-client-id>
NAVER_CLIENT_SECRET=<your-client-secret>
# Redirect URI should match the naver app config.
# If omitted, server uses https://{host}/api/auth/naver/callback.
NAVER_REDIRECT_URI=http://localhost:4173/api/auth/naver/callback
DATABASE_PATH=daycheck.sqlite
SESSION_SECRET=<random-long-secret>
AUTH_SUCCESS_REDIRECT=/?auth=success
